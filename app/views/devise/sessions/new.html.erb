<div class="min-h-[80vh] flex items-center justify-center bg-white px-4">
  <div class="max-w-md w-full border rounded-xl shadow-lg p-8">
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold text-gray-900">Log in</h2>
      <p class="text-gray-500 mt-2">Welcome back to Airbnb Clone</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <div>
        <%= f.label :email, class: "block text-xs font-bold uppercase text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "Email address", class: "w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-black outline-none transition" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-xs font-bold uppercase text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password", placeholder: "Password", class: "w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-black outline-none transition" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "w-4 h-4 accent-black" %>
          <%= f.label :remember_me, class: "text-sm text-gray-600" %>
        </div>
      <% end %>

      <%= f.submit "Continue", class: "w-full bg-[#FF385C] text-white py-3 rounded-lg font-semibold text-lg hover:bg-[#E31C5F] transition active:scale-95 cursor-pointer" %>
    <% end %>

    <div class="mt-6 border-t pt-6 text-center">
      <p class="text-sm text-gray-600">
        Don't have an account? 
        <%= link_to "Sign up", new_registration_path(resource_name), class: "font-semibold underline hover:text-black" %>
      </p>
    </div>
  </div>
</div>