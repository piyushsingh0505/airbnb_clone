<div class="min-h-[80vh] flex items-center justify-center bg-white px-4">
  <div class="max-w-md w-full border rounded-xl shadow-lg p-8">
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold text-gray-900">Finish signing up</h2>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "Email address", class: "w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-black outline-none transition" %>
        <p class="text-[10px] text-gray-500 mt-1">We'll email you to confirm your email address.</p>
      </div>

      <div>
        <%= f.password_field :password, autocomplete: "new-password", placeholder: "Password", class: "w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-black outline-none transition" %>
      </div>

      <div>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm Password", class: "w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-black outline-none transition" %>
      </div>

      <p class="text-[10px] text-gray-500 py-2">
        By selecting <strong>Agree and continue</strong>, I agree to Airbnb’s Terms of Service and Privacy Policy.
      </p>

      <%= f.submit "Agree and continue", class: "w-full bg-[#FF385C] text-white py-3 rounded-lg font-semibold text-lg hover:bg-[#E31C5F] transition active:scale-95 cursor-pointer" %>
    <% end %>
  </div>
</div>