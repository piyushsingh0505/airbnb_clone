<div id="<%= dom_id listing %>" class="group cursor-pointer">
  <%# Image Section %>
  <div class="relative aspect-square overflow-hidden rounded-xl bg-gray-200">
    <% if listing.image_url.present? %>
      <img src="<%= listing.image_url %>" class="h-full w-full object-cover transition group-hover:scale-105 duration-300">
    <% end %>
    
    <%# Heart Icon (Like) %>
    <button class="absolute top-3 right-3">
      <svg xmlns="http://www.w3.org/2000/svg" fill="rgba(0,0,0,0.5)" viewBox="0 0 24 24" stroke-width="1.5" stroke="white" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
      </svg>
    </button>

    <% if listing.price_cents > 1000000 %>
      <div class="absolute top-3 left-3 bg-white px-2 py-1 rounded-md text-[11px] font-bold shadow-sm">
        GUEST FAVORITE
      </div>
    <% end %>
  </div>

  <%# Text Details %>
  <div class="mt-2">
    <div class="flex justify-between items-center">
      <h3 class="text-sm font-bold text-gray-900"><%= listing.city %>, <%= listing.country %></h3>
      <div class="flex items-center gap-1 text-sm">
        <span>★</span>
        <span><%= listing.rating %></span>
      </div>
    </div>
    <p class="text-sm text-gray-500"><%= listing.headline %></p>
    <p class="text-sm text-gray-500">Available now</p>
    <p class="mt-1 text-sm">
      <span class="font-bold">₹<%= number_with_delimiter(listing.price_cents / 100) %></span>
      <span class="font-light text-gray-600">night</span>
    </p>
  </div>

  <%# Admin Links (Sirf development ke liye chote buttons) %>
  <div class="mt-2 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
    <%= link_to 'Edit', edit_listing_path(listing), class: "text-[10px] underline text-gray-400" %>
    <%= button_to 'Delete', listing, method: :delete, class: "text-[10px] underline text-red-400", data: { confirm: 'Are you sure?' } %>
  </div>
</div>