<div class="max-w-[1600px] mx-auto px-4 md:px-10 py-6">
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-x-6 gap-y-10">
    
    <% @listings.each do |listing| %>
      <%= link_to listing_path(listing), class: "group flex flex-col gap-2" do %>
        
        <div class="relative aspect-square w-full overflow-hidden rounded-xl bg-gray-200">
          <% if listing.image_url.present? %>
            <img src="<%= listing.image_url %>" 
                 class="h-full w-full object-cover group-hover:scale-105 transition duration-500 ease-in-out" 
                 alt="<%= listing.city %>">
          <% else %>
            <div class="flex items-center justify-center h-full text-gray-400 text-xs">No Image</div>
          <% end %>

          <div class="absolute top-3 right-3 p-1">
            <svg viewBox="0 0 32 32" class="h-6 w-6 stroke-white stroke-[2px] fill-black/30 hover:fill-[#FF385C] transition">
              <path d="m16 28c7-4.733 14-10 14-17 0-3.866-3.134-7-7-7-2.359 0-4.45 1.123-5.76 2.854l-1.24 1.646-1.24-1.646c-1.31-1.731-3.401-2.854-5.76-2.854-3.866 0-7 3.134-7 7 0 7 7 12.267 14 17z"></path>
            </svg>
          </div>
        </div>

        <div class="flex flex-col">
          <div class="flex justify-between items-center">
            <span class="font-bold text-[15px] text-gray-900"><%= listing.city %>, India</span>
            <div class="flex items-center gap-1 text-[14px]">
              <span class="text-[10px]">★</span> 
              <span class="font-light"><%= listing.rating || "New" %></span>
            </div>
          </div>
          
          <p class="text-gray-500 text-[15px] font-light truncate">
            <%= listing.headline %>
          </p>
          
          <p class="mt-1 text-[15px]">
            <span class="font-bold text-gray-900">₹<%= number_with_delimiter(listing.price_cents / 100) %></span> 
            <span class="font-light text-gray-600">night</span>
          </p>
        </div>
      <% end %>
    <% end %>

  </div>
</div>

<style>
  /* Hide scrollbar logic */
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>